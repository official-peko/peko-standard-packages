//! Implements base runtime functionality for Pekoscript.
//
// Naming standards in this file differ from normal Peko conventions
// since these functions are referenced directly by the compiler.

import ffi@"v0.1.0";

platform windows {
    link libs::windows::rt as object;

    link libs::windows::alloc as object;
    link libs::windows::compiler_abi as object;
    link libs::windows::heap as object;
    link libs::windows::mark as object;
    link libs::windows::pgc as object;
    link libs::windows::roots as object;
    link libs::windows::stackmap as object;
    link libs::windows::threads as object;
    link libs::windows::audit as object;
}

platform macos {
    arch arm {
        link libs::macos::arm::rt as object;

        link libs::macos::arm::alloc as object;
        link libs::macos::arm::compiler_abi as object;
