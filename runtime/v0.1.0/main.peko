        link libs::macos::arm::mark as object;
        link libs::macos::arm::pgc as object;
        link libs::macos::arm::roots as object;
        link libs::macos::arm::stackmap as object;
        link libs::macos::arm::threads as object;
        link libs::macos::arm::audit as object;
    }

    arch x86_64 {
        link libs::macos::x86_64::rt as object;

        link libs::macos::x86_64::alloc as object;
        link libs::macos::x86_64::compiler_abi as object;
        link libs::macos::x86_64::heap as object;
        link libs::macos::x86_64::mark as object;
        link libs::macos::x86_64::pgc as object;
        link libs::macos::x86_64::roots as object;
        link libs::macos::x86_64::stackmap as object;
        link libs::macos::x86_64::threads as object;
        link libs::macos::x86_64::audit as object;
    }
}

